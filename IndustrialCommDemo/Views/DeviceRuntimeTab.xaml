<UserControl x:Class="IndustrialCommDemo.Views.DeviceRuntimeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="170" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="14" CornerRadius="10" Background="#F1F5F9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#17324D" Text="设备运行中心" />
                    <TextBlock x:Name="RuntimeStatusTextBlock" Margin="0,5,0,0" Foreground="#475569" Text="加载 Config/devices.json 后可统一启动设备。" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ReloadButton" Margin="0,0,8,0" Click="ReloadButton_Click" Content="重新加载配置" />
                    <Button x:Name="StartButton" Margin="0,0,8,0" Background="#DCFCE7" Click="StartButton_Click" Content="启动全部设备" />
                    <Button x:Name="StopButton" Background="#FEE2E2" Click="StopButton_Click" Content="停止" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <GroupBox Grid.Row="1" Margin="0,10,0,0" Header="设备状态">
            <DataGrid x:Name="DeviceGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="150" Header="设备" Binding="{Binding Name}" />
                    <DataGridTextColumn Width="140" Header="协议" Binding="{Binding Protocol}" />
                    <DataGridTextColumn Width="180" Header="地址" Binding="{Binding Endpoint}" />
                    <DataGridTextColumn Width="110" Header="状态" Binding="{Binding State}" />
                    <DataGridTextColumn Width="*" Header="最近错误" Binding="{Binding Error}" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Margin="0,10,0,0" Header="实时点位">
            <DataGrid x:Name="ValueGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="120" Header="设备" Binding="{Binding DeviceName}" />
                    <DataGridTextColumn Width="150" Header="点位" Binding="{Binding TagName}" />
                    <DataGridTextColumn Width="140" Header="地址" Binding="{Binding Address}" />
                    <DataGridTextColumn Width="160" Header="值" Binding="{Binding Value}" />
                    <DataGridTextColumn Width="100" Header="质量" Binding="{Binding Quality}" />
                    <DataGridTextColumn Width="180" Header="时间" Binding="{Binding Timestamp}" />
                    <DataGridTextColumn Width="*" Header="错误" Binding="{Binding Error}" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
