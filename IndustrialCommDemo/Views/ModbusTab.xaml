<UserControl x:Class="IndustrialCommDemo.Views.ModbusTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*" /><ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <!-- Connection panel -->
            <GroupBox Header="连接" Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="连接方式" />
                    <ComboBox x:Name="ConnectionTypeComboBox" Grid.Row="0" Grid.Column="1" Margin="0,6,0,6" SelectedIndex="0" SelectionChanged="ConnectionTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Modbus TCP" Tag="Tcp" /><ComboBoxItem Content="Modbus RTU (串口)" Tag="Rtu" />
                    </ComboBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="设备 ID" />
                    <TextBox x:Name="DeviceIdTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,6" Text="modbus-1" />
                    <!-- TCP params -->
                    <TextBlock x:Name="HostLabel" Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="主机" />
                    <TextBox x:Name="HostTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" Text="127.0.0.1" />
                    <TextBlock x:Name="PortLabel" Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="端口" />
                    <TextBox x:Name="PortTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6,0,6" Text="502" />
                    <!-- RTU params (hidden by default) -->
                    <TextBlock x:Name="PortNameLabel" Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="串口号" Visibility="Collapsed" />
                    <ComboBox x:Name="PortNameComboBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" IsEditable="True" Text="COM1" Visibility="Collapsed" />
                    <TextBlock x:Name="BaudRateLabel" Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="波特率" Visibility="Collapsed" />
                    <ComboBox x:Name="BaudRateComboBox" Grid.Row="3" Grid.Column="1" Margin="0,6,0,6" IsEditable="True" Text="9600" Visibility="Collapsed">
                        <ComboBoxItem Content="2400" /><ComboBoxItem Content="4800" /><ComboBoxItem Content="9600" IsSelected="True" />
                        <ComboBoxItem Content="19200" /><ComboBoxItem Content="38400" /><ComboBoxItem Content="57600" /><ComboBoxItem Content="115200" />
                    </ComboBox>
                    <TextBlock x:Name="DataBitsLabel" Grid.Row="4" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="数据位" Visibility="Collapsed" />
                    <ComboBox x:Name="DataBitsComboBox" Grid.Row="4" Grid.Column="1" Margin="0,6,0,6" Visibility="Collapsed">
                        <ComboBoxItem Content="8" IsSelected="True" />
                    </ComboBox>
                    <TextBlock x:Name="ParityLabel" Grid.Row="5" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="校验位" Visibility="Collapsed" />
                    <ComboBox x:Name="ParityComboBox" Grid.Row="5" Grid.Column="1" Margin="0,6,0,6" Visibility="Collapsed">
                        <ComboBoxItem Content="None" Tag="None" /><ComboBoxItem Content="Odd" Tag="Odd" /><ComboBoxItem Content="Even" IsSelected="True" Tag="Even" />
                    </ComboBox>
                    <TextBlock x:Name="StopBitsLabel" Grid.Row="6" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="停止位" Visibility="Collapsed" />
                    <ComboBox x:Name="StopBitsComboBox" Grid.Row="6" Grid.Column="1" Margin="0,6,0,6" Visibility="Collapsed">
                        <ComboBoxItem Content="1" IsSelected="True" Tag="One" /><ComboBoxItem Content="1.5" Tag="OnePointFive" /><ComboBoxItem Content="2" Tag="Two" />
                    </ComboBox>
                    <TextBlock x:Name="SlaveIdLabel" Grid.Row="7" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="从站 ID" />
                    <TextBox x:Name="SlaveIdTextBox" Grid.Row="7" Grid.Column="1" Margin="0,6,0,6" Text="1" />
                    <TextBlock x:Name="ModelLabel" Grid.Row="8" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="地址类型" />
                    <ComboBox x:Name="ModelComboBox" Grid.Row="8" Grid.Column="1" Margin="0,6,0,6" SelectedIndex="0" SelectionChanged="ModelComboBox_SelectionChanged">
                        <ComboBoxItem Content="通用 Modbus" Tag="generic-modbus" />
                        <ComboBoxItem Content="汇川 EasyPLC" Tag="inovance-easyplc" />
                        <ComboBoxItem Content="三菱 Modbus TCP" Tag="mitsubishi-modbus-tcp" />
                    </ComboBox>
                    <TextBlock x:Name="ExampleLabel" Grid.Row="9" Grid.Column="0" Margin="0,8" VerticalAlignment="Top" Text="示例" />
                    <TextBlock x:Name="ExampleAddressTextBlock" Grid.Row="9" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#5B6F82" Text="D100, R200, M0, S10, B5, X17, Y20" />
                    <TextBlock x:Name="RtuTimeoutLabel" Grid.Row="10" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="响应超时（ms）" Visibility="Collapsed" />
                    <TextBox x:Name="RtuTimeoutTextBox" Grid.Row="10" Grid.Column="1" Margin="0,6,0,6" Text="3000" Visibility="Collapsed" />
                    <Border Grid.Row="11" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="10" CornerRadius="10" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                        <TextBlock x:Name="CapabilityTextBlock" TextWrapping="Wrap" Foreground="#475569" Text="协议能力：等待初始化。" />
                    </Border>
                    <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Width="120" Margin="0,0,12,0" Padding="10" Background="#1D4ED8" Foreground="White" BorderThickness="0" Click="ConnectButton_Click" Content="连接" />
                        <Button Width="120" Margin="0,0,12,0" Padding="10" Background="#334155" Foreground="White" BorderThickness="0" Click="DisconnectButton_Click" Content="断开" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="状态：" />
                        <TextBlock x:Name="StatusTextBlock" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#0F766E" Text="未连接" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Operations panel -->
            <GroupBox Header="操作" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="地址" />
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBox x:Name="AddressTextBox" Margin="0,6,0,6" Text="HR0" TextChanged="AddressTextBox_TextChanged" />
                        <ComboBox x:Name="AddressHistoryComboBox" Margin="0,0,0,6" SelectionChanged="AddressHistoryComboBox_SelectionChanged" />
                        <TextBlock x:Name="AddressHintTextBlock" Margin="0,0,0,2" FontSize="12" Foreground="#64748B" Text="支持逗号、分号、换行输入多个地址。" />
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="解析类型" />
                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <ComboBox x:Name="DataTypeComboBox" Margin="0,6,0,3" SelectedIndex="2" SelectionChanged="DataTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Bool" /><ComboBoxItem Content="Int16" /><ComboBoxItem Content="UInt16" />
                            <ComboBoxItem Content="Int32" /><ComboBoxItem Content="UInt32" /><ComboBoxItem Content="Float" />
                            <ComboBoxItem Content="Double" /><ComboBoxItem Content="String" /><ComboBoxItem Content="ByteArray" />
                        </ComboBox>
                        <TextBlock Margin="0,0,0,3" FontSize="12" Foreground="#64748B" Text="仅决定如何解释位或 16 位寄存器，不属于 Modbus 报文。" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="长度" />
                    <TextBox x:Name="LengthTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" Text="1" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="写入值" />
                    <StackPanel Grid.Row="3" Grid.Column="1">
                        <TextBox x:Name="WriteValueTextBox" Margin="0,6,0,6" Text="123" TextChanged="WriteValueTextBox_TextChanged" />
                        <TextBlock x:Name="WriteHintTextBlock" Margin="0,0,0,2" FontSize="12" Foreground="#64748B"
                                   Text="多地址写入时，可填写 1 个值广播，或填写与地址数相同的多个值。" />
                    </StackPanel>
                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="轮询间隔（毫秒）" />
                    <TextBox x:Name="PollIntervalTextBox" Grid.Row="4" Grid.Column="1" Margin="0,6,0,6" Text="1000" />
                    <UniformGrid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,14,0,0" Columns="4">
                        <Button Margin="0,0,8,8" Padding="10" Background="#0891B2" Foreground="White" BorderThickness="0" Click="ReadButton_Click" Content="读取" />
                        <Button Margin="0,0,8,8" Padding="10" Background="#059669" Foreground="White" BorderThickness="0" Click="WriteButton_Click" Content="写入" />
                        <Button Margin="0,0,8,8" Padding="10" Background="#7C3AED" Foreground="White" BorderThickness="0" Click="SubscribeButton_Click" Content="订阅" />
                        <Button Margin="0,0,0,8" Padding="10" Background="#9F1239" Foreground="White" BorderThickness="0" Click="UnsubscribeButton_Click" Content="停止" />
                    </UniformGrid>
                    <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#64748B"
                               Text="X/Y/M/S/B 强制为 Bool 类型。D/R 使用寄存器类型并自动根据 16位、32位、字符串和字节数组建议长度。地址框支持逗号、分号、换行，多地址点击「读取」会自动走批量读取。" />
                    <Border Grid.Row="7" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="12" CornerRadius="12" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Foreground="#17324D" Text="结果" />
                            <TextBlock x:Name="ResultTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#334155" Text="等待中..." />
                            <Border x:Name="RtuFramePanel" Margin="0,12,0,0" Padding="10" Background="#EEF6FF" CornerRadius="8" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="#17324D" Text="RS-485 / Modbus RTU 标准报文（含 CRC）" />
                                    <TextBlock Margin="0,7,0,0" Foreground="#475569" Text="请求（十六进制，可不填 CRC）" />
                                    <TextBox x:Name="RtuRawRequestTextBox" Margin="0,3,0,0" FontFamily="Consolas" Text="01 03 00 00 00 01" />
                                    <StackPanel Margin="0,7,0,2" Orientation="Horizontal">
                                        <CheckBox x:Name="RtuAutoCrcCheckBox" VerticalAlignment="Center" IsChecked="True" Content="自动追加 CRC16" />
                                        <Button Margin="14,0,0,0" Padding="14,6" Background="#2563EB" Foreground="White" BorderThickness="0" Click="RtuRawSendButton_Click" Content="发送原始报文" />
                                    </StackPanel>
                                    <TextBlock Margin="0,7,0,0" Foreground="#0369A1" Text="发送 TX" />
                                    <TextBox x:Name="RtuTxTextBox" Margin="0,3,0,0" IsReadOnly="True" FontFamily="Consolas" Text="等待发送..." />
                                    <TextBlock Margin="0,7,0,0" Foreground="#047857" Text="接收 RX" />
                                    <TextBox x:Name="RtuRxTextBox" Margin="0,3,0,0" IsReadOnly="True" FontFamily="Consolas" Text="等待接收..." />
                                </StackPanel>
                            </Border>
                            <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Foreground="#17324D" Text="读取 / 订阅结果" />
                            <DataGrid x:Name="SubscriptionDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0" MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="110" />
                                    <DataGridTextColumn Header="解析类型" Binding="{Binding DataType}" Width="90" />
                                    <DataGridTextColumn Header="值" Binding="{Binding ValueText}" Width="*" />
                                    <DataGridTextColumn Header="质量" Binding="{Binding QualityText}" Width="110" />
                                    <DataGridTextColumn Header="时间" Binding="{Binding TimestampText}" Width="150" />
                                    <DataGridTextColumn Header="错误" Binding="{Binding ErrorMessage}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Header="说明" Grid.Row="1" Grid.ColumnSpan="2">
                <TextBlock Margin="12" TextWrapping="Wrap" Foreground="#475569"
                           Text="本页面支持 Modbus TCP 与 Modbus RTU（RS-485/RS-232）。RTU 模式会展示线上实际收发的完整标准报文与 CRC 校验结果。" />
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>