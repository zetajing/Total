<UserControl x:Class="IndustrialCommDemo.Views.SiemensS7Tab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="连接" Grid.Column="0" Margin="0,0,12,0">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="设备 ID" />
                    <TextBox x:Name="S7DeviceIdTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6,0,6" Text="s7-1" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="主机" />
                    <TextBox x:Name="S7HostTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,6" Text="127.0.0.1" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="机架" />
                    <TextBox x:Name="S7RackTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" Text="0" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="槽位" />
                    <TextBox x:Name="S7SlotTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6,0,6" Text="1" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8" VerticalAlignment="Top" Text="示例" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#5B6F82"
                               Text="DB1.DBX0.1, DINT %DB200.DBD6, REAL %DB200.DBD10, LREAL P#DB200.DBX20.0" />
                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Width="120" Margin="0,0,12,0" Padding="10" Background="#1D4ED8" Foreground="White" BorderThickness="0" Click="ConnectButton_Click" Content="连接" />
                        <Button Width="120" Margin="0,0,12,0" Padding="10" Background="#334155" Foreground="White" BorderThickness="0" Click="DisconnectButton_Click" Content="断开" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="状态：" />
                        <TextBlock x:Name="StatusTextBlock" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#0F766E" Text="未连接" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="操作" Grid.Column="1">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="地址" />
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBox x:Name="S7AddressTextBox" Margin="0,6,0,6" Text="DB1.DBW0" TextChanged="AddressTextBox_TextChanged" />
                        <ComboBox x:Name="S7AddressHistoryComboBox" Margin="0,0,0,6" SelectionChanged="AddressHistoryComboBox_SelectionChanged" />
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="数据类型" />
                    <ComboBox x:Name="S7DataTypeComboBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,6" SelectedIndex="1" SelectionChanged="DataTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Bool" /><ComboBoxItem Content="Byte" /><ComboBoxItem Content="Char" />
                        <ComboBoxItem Content="Int16" /><ComboBoxItem Content="UInt16" /><ComboBoxItem Content="Int32" />
                        <ComboBoxItem Content="UInt32" /><ComboBoxItem Content="Float" /><ComboBoxItem Content="Double" />
                        <ComboBoxItem Content="String" /><ComboBoxItem Content="ByteArray" />
                    </ComboBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="长度" />
                    <TextBox x:Name="S7LengthTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" Text="1" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="写入值" />
                    <TextBox x:Name="S7WriteValueTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6,0,6" Text="123" />
                    <UniformGrid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,14,0,0" Columns="2">
                        <Button Margin="0,0,8,8" Padding="10" Background="#0891B2" Foreground="White" BorderThickness="0" Click="ReadButton_Click" Content="读取" />
                        <Button Margin="8,0,0,8" Padding="10" Background="#059669" Foreground="White" BorderThickness="0" Click="WriteButton_Click" Content="写入" />
                    </UniformGrid>
                    <Border Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="12" CornerRadius="12" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Foreground="#17324D" Text="结果" />
                            <TextBlock x:Name="ResultTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#334155" Text="等待中..." />
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
