<UserControl x:Class="IndustrialCommDemo.Views.JsonConfigTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="devices.json">
                <TextBox x:Name="DeviceJsonTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </GroupBox>

            <GroupBox x:Name="PointConfigGroupBox" Grid.Row="2" Header="points/*.json">
                <TextBox x:Name="PointJsonTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </GroupBox>
        </Grid>

        <Grid Grid.Column="1" Margin="14,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="16" CornerRadius="12" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.ColumnSpan="2" Margin="0,0,0,10" FontSize="17" FontWeight="SemiBold" Foreground="#17324D" Text="JSON 快速部署示例" />
                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="设备名" />
                    <TextBox x:Name="DeviceNameTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,4"
                             Text="plc1"
                             LostKeyboardFocus="DeviceNameTextBox_LostKeyboardFocus" />
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0" Orientation="Horizontal">
                        <Button Width="110" Click="ReloadConfigButton_Click" Content="重新加载" />
                        <Button Width="110" Margin="10,0,0,0" Click="SaveConfigButton_Click" Content="保存配置" />
                        <Button Width="110" Margin="10,0,0,0" Background="#2563EB" Foreground="White" BorderThickness="0" Click="TestConnectionButton_Click" Content="测试连接" />
                        <Button Width="110" Margin="10,0,0,0" Background="#0F766E" Foreground="White" BorderThickness="0" Click="ReadPointsButton_Click" Content="批量读取" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="0,12,0,0" Padding="14" CornerRadius="12" Background="#EEF6FF" BorderBrush="#BBD7F0" BorderThickness="1">
                <TextBlock x:Name="JsonConfigStatusTextBlock" Foreground="#17324D" TextWrapping="Wrap" Text="修改左侧 JSON 后，可直接测试连接或批量读取。" />
            </Border>

            <DataGrid x:Name="JsonReadResultGrid"
                      Grid.Row="2"
                      Margin="0,12,0,0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.1*" />
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="1*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.9*" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="1.2*" />
                    <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="0.9*" />
                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="1.6*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
