<UserControl x:Class="IndustrialCommDemo.Views.JsonConfigTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 左侧编辑部署目录中的设备配置和当前设备点位表。 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="设备配置">
                <TabControl>
                    <TabItem Header="常用参数">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock VerticalAlignment="Center" Text="设备名称" />
                                <TextBox x:Name="DeviceNameTextBox" Grid.Column="1" Margin="4" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="协议" />
                                <ComboBox x:Name="ProtocolComboBox" Grid.Column="3" Margin="4" SelectionChanged="ProtocolComboBox_SelectionChanged">
                                    <ComboBoxItem Content="modbus-tcp" />
                                    <ComboBoxItem Content="modbus-rtu" />
                                    <ComboBoxItem Content="siemens-s7" />
                                    <ComboBoxItem Content="mitsubishi-mc" />
                                    <ComboBoxItem Content="opc-ua" />
                                    <ComboBoxItem Content="mqtt" />
                                    <ComboBoxItem Content="redis" />
                                </ComboBox>

                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="设备 ID" />
                                <TextBox x:Name="DeviceIdTextBox" Grid.Row="1" Grid.Column="1" Margin="4" />
                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="操作超时(ms)" />
                                <TextBox x:Name="OperationTimeoutTextBox" Grid.Row="1" Grid.Column="3" Margin="4" />

                                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="点位文件" />
                                <TextBox x:Name="PointsFileTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="4" />

                                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="轮询(ms)" />
                                <TextBox x:Name="PollingIntervalTextBox" Grid.Row="3" Grid.Column="1" Margin="4" />
                                <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Text="重连(ms)" />
                                <TextBox x:Name="ReconnectDelayTextBox" Grid.Row="3" Grid.Column="3" Margin="4" />

                                <CheckBox x:Name="EnabledCheckBox" Grid.Row="4" Grid.ColumnSpan="4" Margin="4,8" VerticalAlignment="Center" Content="启用并由运行中心管理" />

                                <TextBlock Grid.Row="5" VerticalAlignment="Top" Margin="0,8,0,0" Text="协议 settings" />
                                <TextBox x:Name="SettingsJsonTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Height="150" Margin="4"
                                         AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12"
                                         HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />

                                <WrapPanel Grid.Row="6" Grid.ColumnSpan="4" HorizontalAlignment="Right">
                                    <Button Margin="4" Click="AddDeviceButton_Click" Content="新增设备" />
                                    <Button Margin="4" Click="DeleteDeviceButton_Click" Content="删除设备" />
                                    <Button Margin="4" Click="FormatSettingsButton_Click" Content="格式化 settings" />
                                    <Button Margin="4" Background="#2563EB" Foreground="White" Click="ApplyDeviceFormButton_Click" Content="应用到 JSON" />
                                </WrapPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="高级 JSON">
                        <TextBox x:Name="DeviceJsonTextBox"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" />
                    </TabItem>
                </TabControl>
            </GroupBox>

            <GroupBox x:Name="PointConfigGroupBox" Grid.Row="2" Header="points/*.json">
                <TabControl x:Name="PointEditorTabControl">
                    <TabItem Header="点位表格">
                        <DataGrid x:Name="PointEditorGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1.1*" Header="名称" Binding="{Binding Name}" />
                                <DataGridTextColumn Width="1.2*" Header="地址" Binding="{Binding Address}" />
                                <DataGridComboBoxColumn x:Name="PointTypeColumn" Width="1*" Header="类型" SelectedItemBinding="{Binding Type}" />
                                <DataGridTextColumn Width="0.7*" Header="长度" Binding="{Binding Length}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="高级 JSON">
                        <TextBox x:Name="PointJsonTextBox"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" />
                    </TabItem>
                </TabControl>
            </GroupBox>
        </Grid>

        <!-- 右侧执行连接诊断、批量读取并展示点位质量。 -->
        <Grid Grid.Column="1" Margin="14,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="16" CornerRadius="12" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.ColumnSpan="2" Margin="0,0,0,10" FontSize="17" FontWeight="SemiBold" Foreground="#17324D" Text="JSON 快速部署示例" />
                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="设备" />
                    <ComboBox x:Name="DeviceNameComboBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,4"
                             SelectionChanged="DeviceNameComboBox_SelectionChanged" />
                    <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                        <Button Width="100" Margin="0,0,8,8" Click="ReloadConfigButton_Click" Content="重新加载" />
                        <Button Width="100" Margin="0,0,8,8" Click="SaveConfigButton_Click" Content="保存配置" />
                        <Button Width="100" Margin="0,0,8,8" Click="ValidateConfigButton_Click" Content="校验配置" />
                        <Button Width="100" Margin="0,0,8,8" Background="#2563EB" Foreground="White" BorderThickness="0" Click="TestConnectionButton_Click" Content="测试连接" />
                        <Button Width="100" Margin="0,0,8,8" Background="#0F766E" Foreground="White" BorderThickness="0" Click="ReadPointsButton_Click" Content="批量读取" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="0,12,0,0" Padding="14" CornerRadius="12" Background="#EEF6FF" BorderBrush="#BBD7F0" BorderThickness="1">
                <TextBlock x:Name="JsonConfigStatusTextBlock" Foreground="#17324D" TextWrapping="Wrap" Text="修改左侧 JSON 后，可直接测试连接或批量读取。" />
            </Border>

            <DataGrid x:Name="JsonReadResultGrid"
                      Grid.Row="2"
                      Margin="0,12,0,0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.1*" />
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="1*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.9*" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="1.2*" />
                    <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="0.9*" />
                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="1.6*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
