<UserControl x:Class="IndustrialCommDemo.Views.SocketTcpTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="TCP 服务端" Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="监听 IP" />
                    <TextBox x:Name="SocketServerIpTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6,0,6" Text="0.0.0.0" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="端口" />
                    <TextBox x:Name="SocketServerPortTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,6" Text="9000" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="状态" />
                    <TextBlock x:Name="ServerStatusTextBlock" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Foreground="#0F766E" Text="已停止" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="会话数" />
                    <TextBlock x:Name="ServerSessionsTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="0" />
                    <CheckBox x:Name="EchoCheckBox" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0" IsChecked="True" Content="将接收到的文本回显给客户端" />
                    <UniformGrid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,14,0,0" Columns="2">
                        <Button Margin="0,0,8,0" Padding="10" Background="#1D4ED8" Foreground="White" BorderThickness="0" Click="StartServerButton_Click" Content="启动服务端" />
                        <Button Margin="8,0,0,0" Padding="10" Background="#334155" Foreground="White" BorderThickness="0" Click="StopServerButton_Click" Content="停止服务端" />
                    </UniformGrid>
                </Grid>
            </GroupBox>

            <GroupBox Header="TCP 客户端" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="服务端主机" />
                    <TextBox x:Name="SocketClientHostTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6,0,6" Text="127.0.0.1" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="服务端端口" />
                    <TextBox x:Name="SocketClientPortTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,6" Text="9000" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="状态" />
                    <TextBlock x:Name="ClientStatusTextBlock" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Foreground="#0F766E" Text="未连接" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8" VerticalAlignment="Center" Text="最近接收" />
                    <TextBlock x:Name="ClientLastReceivedTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Text="（无）" />
                    <UniformGrid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,14,0,0" Columns="2">
                        <Button Margin="0,0,8,0" Padding="10" Background="#0891B2" Foreground="White" BorderThickness="0" Click="ConnectClientButton_Click" Content="连接客户端" />
                        <Button Margin="8,0,0,0" Padding="10" Background="#334155" Foreground="White" BorderThickness="0" Click="DisconnectClientButton_Click" Content="断开客户端" />
                    </UniformGrid>
                </Grid>
            </GroupBox>

            <GroupBox Header="消息流" Grid.Row="1" Grid.ColumnSpan="2">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,4" FontWeight="SemiBold" Text="服务端发送" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" FontWeight="SemiBold" Text="客户端发送" />
                    <TextBox x:Name="SocketServerMessageTextBox" Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" MinHeight="90" TextWrapping="Wrap" AcceptsReturn="True" Text="服务端广播" />
                    <TextBox x:Name="SocketClientMessageTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" MinHeight="90" TextWrapping="Wrap" AcceptsReturn="True" Text="客户端消息" />
                    <Grid Grid.Row="2" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="0,0,12,0" Padding="10" Background="#059669" Foreground="White" BorderThickness="0" Click="SendFromServerButton_Click" Content="服务端广播" />
                        <Button Grid.Column="1" Margin="0,0,0,0" Padding="10" Background="#7C3AED" Foreground="White" BorderThickness="0" Click="SendFromClientButton_Click" Content="客户端发送" />
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
