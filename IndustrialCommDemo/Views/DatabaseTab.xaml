<UserControl x:Class="IndustrialCommDemo.Views.DatabaseTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="14" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="18" CornerRadius="14" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.ColumnSpan="2" Margin="0,0,0,12" FontSize="18" FontWeight="SemiBold" Foreground="#17324D" Text="数据库历史数据" />

                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="数据库类型" />
                    <ComboBox x:Name="DatabaseProviderComboBox" Grid.Row="1" Grid.Column="1" Margin="0,6"
                              SelectedIndex="0" SelectionChanged="DatabaseProviderComboBox_SelectionChanged">
                        <ComboBoxItem Content="SQL Server" Tag="sqlserver" />
                        <ComboBoxItem Content="MySQL 8.0+" Tag="mysql" />
                    </ComboBox>
                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="连接字符串" />
                    <TextBox x:Name="ConnectionStringTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6"
                             Text="Server=localhost;Database=UpperComputerDb;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;" />
                    <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="历史表" />
                    <TextBox x:Name="TableNameTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6" Text="dbo.IndustrialDataHistory" />
                    <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="自动记录" />
                    <CheckBox x:Name="EnabledCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,10" VerticalAlignment="Center"
                              Focusable="False" IsHitTestVisible="False"
                              Content="保存 Modbus / S7 / MC 的读取和轮询结果" />
                    <TextBlock x:Name="ProviderHintTextBlock" Grid.Row="5" Grid.Column="1" Margin="0,2,0,0"
                               Foreground="#64748B" TextWrapping="Wrap"
                               Text="SQL Server 使用 schema.table；建议使用 Windows 身份验证。" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal">
                <Button x:Name="StartButton" Width="150" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0"
                        Click="StartButton_Click" Content="测试并启用" />
                <Button x:Name="StopButton" Width="110" Margin="10,0,0,0" Padding="12,8" Background="#E2E8F0" BorderBrush="#CBD5E1"
                        Click="StopButton_Click" Content="停止记录" />
            </StackPanel>

            <Border Grid.Row="2" Margin="0,16,0,0" Padding="14" CornerRadius="12" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="#1E3A5F" Text="状态" />
                    <TextBlock x:Name="StatusTextBlock" Margin="0,6,0,0" Foreground="#475569" Text="未启用" />
                    <TextBlock x:Name="MetricsTextBlock" Margin="0,6,0,0" Foreground="#475569" Text="队列 0 · 已接收 0 · 已写入 0 · 丢弃 0 · 失败 0" />
                </StackPanel>
            </Border>

            <TabControl Grid.Row="3" Margin="0,16,0,0">
                <TabItem Header="实时流水">
                    <Border Padding="14" Background="#FFFFFF" BorderBrush="#D8E2EE" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Foreground="#17324D" Text="实时历史数据" />
                                <TextBlock x:Name="HistoryStatusTextBlock" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="#64748B" Text="连接数据库后自动刷新" />
                            </DockPanel>
                            <DataGrid x:Name="HistoryDataGrid" Grid.Row="1" Height="340" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False" EnableRowVirtualization="True"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
                                    <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="105" />
                                    <DataGridTextColumn Header="设备" Binding="{Binding DeviceId}" Width="110" />
                                    <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="105" />
                                    <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="85" />
                                    <DataGridTextColumn Header="值" Binding="{Binding ValueText}" Width="*" />
                                    <DataGridTextColumn Header="质量" Binding="{Binding Quality}" Width="75" />
                                    <DataGridTextColumn Header="采集时间" Binding="{Binding Timestamp}" Width="165" />
                                    <DataGridTextColumn Header="错误" Binding="{Binding ErrorMessage}" Width="150" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="最新值">
                    <Grid Margin="10">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock VerticalAlignment="Center" Text="设备："/><ComboBox x:Name="LatestDeviceComboBox" Width="180" IsEditable="True"/>
                            <Button Margin="10,0,0,0" Padding="14,6" Click="LatestRefreshButton_Click" Content="刷新最新值"/>
                        </StackPanel>
                        <DataGrid x:Name="LatestDataGrid" Grid.Row="1" Height="340" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="设备" Binding="{Binding DeviceId}" Width="120"/><DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="110"/>
                                <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="100"/><DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="80"/>
                                <DataGridTextColumn Header="最新值" Binding="{Binding ValueText}" Width="*"/><DataGridTextColumn Header="质量" Binding="{Binding Quality}" Width="100"/>
                                <DataGridTextColumn Header="采集时间" Binding="{Binding Timestamp}" Width="170"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="历史管理">
                    <Grid Margin="10">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock VerticalAlignment="Center" Text="设备"/><ComboBox x:Name="QueryDeviceComboBox" Width="130" Margin="5,0,10,0" IsEditable="True"/>
                            <TextBlock VerticalAlignment="Center" Text="地址"/><TextBox x:Name="QueryAddressTextBox" Width="100" Margin="5,0"/><CheckBox x:Name="QueryContainsCheckBox" VerticalAlignment="Center" Margin="5,0,10,0" Content="包含"/>
                            <TextBlock VerticalAlignment="Center" Text="协议"/><ComboBox x:Name="QueryProtocolComboBox" Width="110" Margin="5,0,10,0"/>
                            <TextBlock VerticalAlignment="Center" Text="类型"/><ComboBox x:Name="QueryDataTypeComboBox" Width="100" Margin="5,0,10,0"/>
                            <TextBlock VerticalAlignment="Center" Text="质量"/><ComboBox x:Name="QueryQualityComboBox" Width="100" Margin="5,0"/>
                        </WrapPanel>
                        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                            <TextBlock VerticalAlignment="Center" Text="开始"/><TextBox x:Name="QueryFromTextBox" Width="145" Margin="5,0,10,0" ToolTip="yyyy-MM-dd HH:mm:ss"/>
                            <TextBlock VerticalAlignment="Center" Text="结束"/><TextBox x:Name="QueryToTextBox" Width="145" Margin="5,0,10,0" ToolTip="yyyy-MM-dd HH:mm:ss"/>
                            <TextBlock VerticalAlignment="Center" Text="每页"/><ComboBox x:Name="QueryPageSizeComboBox" Width="70" Margin="5,0,10,0" SelectedIndex="1"><ComboBoxItem Content="50"/><ComboBoxItem Content="100"/><ComboBoxItem Content="200"/></ComboBox>
                            <Button Padding="12,5" Click="QueryButton_Click" Content="查询"/><Button Margin="6,0" Padding="12,5" Click="QueryResetButton_Click" Content="重置"/>
                        </WrapPanel>
                        <DockPanel Grid.Row="2" Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"><Button Padding="10,4" Click="PreviousPageButton_Click" Content="上一页"/><Button Margin="6,0" Padding="10,4" Click="NextPageButton_Click" Content="下一页"/><TextBlock x:Name="QueryStatusTextBlock" Margin="10,5" Text="未查询"/></StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><Button Padding="10,4" Click="ExportButton_Click" Content="导出 CSV"/><Button Margin="6,0" Padding="10,4" Click="DeleteButton_Click" Content="删除筛选结果"/><ComboBox x:Name="RetentionComboBox" Width="80" SelectedIndex="1"><ComboBoxItem Content="7天" Tag="7"/><ComboBoxItem Content="30天" Tag="30"/><ComboBoxItem Content="90天" Tag="90"/><ComboBoxItem Content="180天" Tag="180"/></ComboBox><Button Margin="6,0,0,0" Padding="10,4" Click="CleanupButton_Click" Content="清理旧数据"/></StackPanel>
                        </DockPanel>
                        <DataGrid x:Name="QueryDataGrid" Grid.Row="3" Height="340" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="65"/><DataGridTextColumn Header="设备" Binding="{Binding DeviceId}" Width="110"/><DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="100"/>
                                <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="95"/><DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="75"/><DataGridTextColumn Header="值" Binding="{Binding ValueText}" Width="*"/>
                                <DataGridTextColumn Header="质量" Binding="{Binding Quality}" Width="90"/><DataGridTextColumn Header="时间" Binding="{Binding Timestamp}" Width="165"/><DataGridTextColumn Header="错误" Binding="{Binding ErrorMessage}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>

            <TextBlock Grid.Row="4" Margin="0,14,0,0" Foreground="#64748B" TextWrapping="Wrap"
                       Text="数据库只负责历史记录，不参与实时控制。实时流水、最新值和历史管理互不影响；删除与保留期清理均需要确认。" />
        </Grid>
    </ScrollViewer>
</UserControl>
