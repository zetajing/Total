                <!--
                    数据库页只配置历史数据旁路，不参与任何 PLC 实时控制。
                    连接字符串默认使用 Windows 身份验证，因此不需要在配置文件中保存数据库密码。
                -->
                <TabItem Header="数据库">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="18" MaxWidth="920" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Padding="18" CornerRadius="14" Background="#F8FAFC" BorderBrush="#D8E2EE" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="620" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.ColumnSpan="2"
                                               Margin="0,0,0,12"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17324D"
                                               Text="SQL Server 历史数据" />

                                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="连接字符串" />
                                    <TextBox x:Name="DatabaseConnectionStringTextBox"
                                             Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,6"
                                             Text="Server=localhost;Database=UpperComputerDb;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;" />

                                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="历史表" />
                                    <TextBox x:Name="DatabaseTableNameTextBox"
                                             Grid.Row="2"
                                             Grid.Column="1"
                                             Margin="0,6"
                                             Text="dbo.IndustrialDataHistory" />

                                    <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="自动记录" />
                                    <!--
                                        这个复选框是只读状态指示器，真正的启停由下面两个按钮完成。
                                        这样可以避免用户只勾选复选框，却误以为数据库已经完成连接。
                                    -->
                                    <CheckBox x:Name="DatabaseEnabledCheckBox"
                                              Grid.Row="3"
                                              Grid.Column="1"
                                              Margin="0,10"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              IsHitTestVisible="False"
                                              Content="保存 Modbus / S7 / MC 的读取和轮询结果" />
                                </Grid>
                            </Border>

                            <!--“测试并启用”会验证连接并自动建表；验证失败时不会启动后台记录器。-->
                            <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal">
                                <Button Width="150"
                                        Padding="12,8"
                                        Background="#2563EB"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="DatabaseStartButton_Click"
                                        Content="测试并启用" />
                                <Button Width="110"
                                        Margin="10,0,0,0"
                                        Padding="12,8"
                                        Background="#E2E8F0"
                                        BorderBrush="#CBD5E1"
                                        Click="DatabaseStopButton_Click"
                                        Content="停止记录" />
                            </StackPanel>

                            <Border Grid.Row="2" Margin="0,16,0,0" Padding="14" CornerRadius="12" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="#1E3A5F" Text="状态" />
                                    <TextBlock x:Name="DatabaseStatusTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="#475569"
                                               Text="未启用" />
                                    <TextBlock x:Name="DatabaseRecorderMetricsTextBlock" Margin="0,6,0,0" Foreground="#475569" Text="队列 0 · 已接收 0 · 已写入 0 · 丢弃 0 · 失败 0" />
                                </StackPanel>
                            </Border>

                            <TabControl Grid.Row="3" Margin="0,16,0,0">
                              <TabItem Header="实时流水">
                               <Border Padding="14" Background="#FFFFFF" BorderBrush="#D8E2EE" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Foreground="#17324D" Text="实时历史数据" />
                                        <TextBlock x:Name="DatabaseHistoryStatusTextBlock"
                                                   DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#64748B"
                                                   Text="连接数据库后自动刷新" />
                                    </DockPanel>
                                    <DataGrid x:Name="DatabaseHistoryDataGrid"
                                              Grid.Row="1"
                                              Height="340"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              EnableRowVirtualization="True"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
                                            <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="105" />
                                            <DataGridTextColumn Header="设备" Binding="{Binding DeviceId}" Width="110" />
                                            <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="105" />
                                            <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="85" />
                                            <DataGridTextColumn Header="值" Binding="{Binding ValueText}" Width="*" />
                                            <DataGridTextColumn Header="质量" Binding="{Binding Quality}" Width="75" />
                                            <DataGridTextColumn Header="采集时间" Binding="{Binding Timestamp}" Width="165" />
                                            <DataGridTextColumn Header="错误" Binding="{Binding ErrorMessage}" Width="150" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                               </Border>
