                                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock VerticalAlignment="Center" Text="设备："/><ComboBox x:Name="DatabaseLatestDeviceComboBox" Width="180" IsEditable="True"/>
