                                      <DataGridTextColumn Header="设备" Binding="{Binding DeviceId}" Width="120"/><DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="110"/>
                                      <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="100"/><DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="80"/>
                                      <DataGridTextColumn Header="最新值" Binding="{Binding ValueText}" Width="*"/><DataGridTextColumn Header="质量" Binding="{Binding Quality}" Width="100"/>
                                      <DataGridTextColumn Header="采集时间" Binding="{Binding Timestamp}" Width="170"/>
