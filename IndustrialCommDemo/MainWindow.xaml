<Window x:Class="IndustrialCommDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:IndustrialCommDemo.Views"
        mc:Ignorable="d"
        Title="通讯"
        Icon="Assets/industrial-comm-icon.png"
        Width="1280"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Padding="18,14" CornerRadius="18" Background="#183A5C">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="工业通讯 Demo" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#A8C2DB" Text="设备连接、数据读写与运行诊断" />
                </StackPanel>
                <Border Grid.Column="1" Padding="14,8" VerticalAlignment="Center" CornerRadius="12" Background="#244D73">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12" Foreground="#A8C2DB" Text="状态" />
                        <TextBlock x:Name="HeaderStatusTextBlock" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#86EFAC" Text="就绪" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Tab control: all tabs are now UserControls -->
        <Border Grid.Row="1" Margin="0,12" Padding="12" CornerRadius="18" Background="White">
            <TabControl x:Name="ProtocolTabControl">
                <TabItem Header="Modbus TCP / RTU">
                    <views:ModbusTab x:Name="ModbusControlTag" />
                </TabItem>
                <TabItem Header="Siemens S7">
                    <views:SiemensS7Tab x:Name="S7ControlTag" />
                </TabItem>
                <TabItem Header="Mitsubishi MC">
                    <views:MitsubishiMcTab x:Name="McControlTag" />
                </TabItem>
                <TabItem Header="JSON 配置">
                    <views:JsonConfigTab x:Name="JsonConfigControlTag" />
                </TabItem>
                <TabItem Header="Socket TCP">
                    <views:SocketTcpTab x:Name="SocketControlTag" />
                </TabItem>
                <TabItem Header="MES">
                    <views:MesTab x:Name="MesControlTag" />
                </TabItem>
                <TabItem Header="数据库">
                    <views:DatabaseTab x:Name="DatabaseControlTag" />
                </TabItem>
                <TabItem Header="网卡设置">
                    <views:NetworkSettingsTab x:Name="NetworkControlTag" />
                </TabItem>
                <TabItem Header="存储设置">
                    <views:StorageTab x:Name="StorageControlTag" />
                </TabItem>
            </TabControl>
        </Border>

        <!-- Log panel (stays in MainWindow) -->
        <Border Grid.Row="2" Padding="16" CornerRadius="18" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#17324D" Text="运行日志" />
                    <Button Grid.Column="1" Padding="8" Background="#E2E8F0" BorderBrush="#CBD5E1" Click="ClearLogButton_Click" Content="清空日志" />
                </Grid>
                <TabControl x:Name="LogTabControl" Grid.Row="1" Margin="0,10,0,0">
                    <TabItem Header="Demo Log">
                        <TextBox x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" FontFamily="Consolas" Background="#0F172A" Foreground="#D4E4FF" BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="SDK Log">
                        <TextBox x:Name="SdkLogTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" FontFamily="Consolas" Background="#111827" Foreground="#BAE6FD" BorderThickness="0" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>
